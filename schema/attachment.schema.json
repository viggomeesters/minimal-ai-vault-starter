{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "type",
    "filename",
    "media_type",
    "size_bytes",
    "sha256",
    "storage_path",
    "source_id",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "filename": {
      "type": "string"
    },
    "media_type": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "storage_path": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
